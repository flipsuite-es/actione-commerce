# ---- Supabase (crea un proyecto gratis en https://supabase.com) ----
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
# Project Settings -> API -> service_role (SECRETO, solo servidor; nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Nombre del bucket de imágenes (créalo público en Storage). Por defecto: product-images
NEXT_PUBLIC_SUPABASE_BUCKET=product-images
